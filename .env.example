MODEL_NAME=ai-coding

# Anthropic Messages API 配置（用于 examples/day02/ex_002_anthropic_chat_client.ts）
# 真实 ANTHROPIC_AUTH_TOKEN 只写到 .env（gitignored），本文件只放占位
